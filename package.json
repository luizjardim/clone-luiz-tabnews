{
  "name": "clone-luiz-tabnews",
  "version": "1.0.0",
  "description": "Um clone do tabnews.com.br como ferramenta educacional e aprendizagem",
  "main": "index.js",
  "scripts": {
    "dev": "node infra/scripts/dev.js",
    "dev:server": "next dev",
    "test": "npm run services:up && npm run services:wait:database && npm run test:run",
    "posttest": "npm run services:stop",
    "test:run": "concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "test:watch": "npm run services:up && npm run services:wait:database && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --watchAll --runInBand --verbose\"",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "prepare": "husky",
    "commit": "cz"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "17.3.1",
    "dotenv-expand": "12.0.3",
    "next": "16.2.1",
    "node-pg-migrate": "6.2.2",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swr": "2.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.27.0",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.1",
    "husky": "9.1.7",
    "jest": "30.3.0",
    "prettier": "3.8.1"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
